# Database
DB_USER=postgres
DB_HOST=localhost
DB_NAME=elearning
DB_PASSWORD=your_password
DB_PORT=5432

# Authentication
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=1d

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Email (Nodemailer config)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@speak-ai.com

# Client URL (for links)
CLIENT_URL=http://localhost:5173
PORT=5000

# Cloudinary Config
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ===== SPEECH STACK =====

# OpenAI Whisper - Speech Recognition (nhận dạng giọng nói)
# Lấy tại: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key

# Groq - AI Evaluation with Llama 3 (chấm điểm phát âm, miễn phí)
# Lấy tại: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key

# ElevenLabs - English TTS (đọc tiếng Anh)
# Lấy tại: https://elevenlabs.io/app/speech-synthesis
ELEVENLABS_API_KEY=your_elevenlabs_api_key
# Voice ID tiếng Anh (ví dụ: "21m00Tcm4TlvDq8ikWAM" là giọng Rachel)
ELEVENLABS_VOICE_ID_EN=21m00Tcm4TlvDq8ikWAM
# Voice ID tiếng Việt (Tìm voice tiếng Việt tại: https://elevenlabs.io/voice-library)
ELEVENLABS_VOICE_ID_VI=your_vietnamese_voice_id
sk_48f3540c93077cb54240d55ac0806076b878c8e29fdc841f
sk_58e57a819f7e2c6bdf41520a5de78355712091b11e783bd7
